generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MENTOR
  MENTEE
  ADMIN
}

enum GoalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  bio       String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Mentor-specific
  inviteCode     String?  @unique
  mentorships    Mentorship[] @relation("MentorRelation")
  assignedTasks  Task[]       @relation("TaskAssignedBy")
  sessions       Session[]    @relation("SessionMentor")

  // Mentee-specific
  enrollments    Mentorship[] @relation("MenteeRelation")
  goals          Goal[]
  receivedTasks  Task[]       @relation("TaskAssignedTo")
  menteeSession  Session[]    @relation("SessionMentee")

  // Chat
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Mentorship {
  id        String   @id @default(uuid())
  mentor    User     @relation("MentorRelation", fields: [mentorId], references: [id])
  mentorId  String
  mentee    User     @relation("MenteeRelation", fields: [menteeId], references: [id])
  menteeId  String
  createdAt DateTime @default(now())

  @@unique([mentorId, menteeId])
}

model Goal {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      GoalStatus @default(PENDING)
  mentee      User       @relation(fields: [menteeId], references: [id])
  menteeId    String
  mentorNote  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus @default(ASSIGNED)
  dueDate      DateTime?
  assignedBy   User       @relation("TaskAssignedBy", fields: [mentorId], references: [id])
  mentorId     String
  assignedTo   User       @relation("TaskAssignedTo", fields: [menteeId], references: [id])
  menteeId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Session {
  id          String   @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  mentor      User     @relation("SessionMentor", fields: [mentorId], references: [id])
  mentorId    String
  mentee      User     @relation("SessionMentee", fields: [menteeId], references: [id])
  menteeId    String
  createdAt   DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  content    String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  senderId   String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  receiverId String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}
